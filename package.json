{
  "name": "qa-automation-framework",
  "version": "1.0.0",
  "description": "Framework de automatización de tests Web con WebdriverIO, Cucumber y TypeScript, usando Page Object Model",
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:smoke": "wdio run ./wdio.conf.ts --cucumberOpts.tagExpression='@smoke'",
    "test:regression": "wdio run ./wdio.conf.ts --cucumberOpts.tagExpression='@regression'",
    "lint": "eslint . --ext .ts"
  },
  "keywords": ["qa", "automation", "webdriverio", "cucumber", "typescript", "pageobjectmodel"],
  "license": "MIT",
  "devDependencies": {
    "@wdio/cli": "^8.39.0",
    "@wdio/cucumber-framework": "^8.39.0",
    "@wdio/local-runner": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "@wdio/allure-reporter": "^8.39.0",
    "@cucumber/cucumber": "^10.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.15",
    "eslint": "^8.57.0"
  }
}
